{
  "name": "auto-job-application-helper-extension",
  "version": "0.1.0",
  "description": "Chrome extension for auto job application assistance",
  "scripts": {
    "test": "jest --runInBand",
    "test:unit": "jest src/__tests__/unit --runInBand",
    "test:property": "jest src/__tests__/property --runInBand",
    "build": "node build.js",
    "bundle": "node -e \"require('esbuild').build({entryPoints:['src/content.js'],bundle:true,outfile:'src/content.bundle.js',format:'iife',target:'chrome100',platform:'browser'}).then(()=>console.log('content.bundle.js built'))\""
  },
  "devDependencies": {
    "@babel/preset-env": "^7.29.2",
    "@types/jest": "^29.5.12",
    "archiver": "^6.0.1",
    "esbuild": "^0.27.4",
    "fast-check": "^3.15.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  },
  "jest": {
    "testEnvironment": "jsdom",
    "testMatch": [
      "**/__tests__/**/*.test.[jt]s",
      "**/__tests__/**/*.property.[jt]s"
    ]
  }
}
